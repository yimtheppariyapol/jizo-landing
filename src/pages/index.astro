<!-- 3D signature: ธรณีประตูแห่งผัสสะ: InstancedMesh torii gate + drifting sense-motes; camera dollies through on scroll. Content-first (try/catch so text never depends on WebGL), reduce-motion + theme aware, ~1 draw call. -->
<script is:inline type="importmap">
{ "imports": { "three": "https://cdn.jsdelivr.net/npm/three@0.169.0/build/three.module.js" } }
</script>
<script is:inline type="module">
import * as THREE from 'three';
try {
  const canvas = document.getElementById('gate');
  const hero = document.querySelector('.hero');
  if (!canvas || !hero) throw new Error('gate: no canvas/hero');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true, powerPreference: 'high-performance' });
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
  const W = () => canvas.clientWidth || innerWidth;
  const H = () => canvas.clientHeight || innerHeight;
  renderer.setSize(W(), H(), false);

  const scene = new THREE.Scene();
  const css = (v, fb) => (getComputedStyle(document.documentElement).getPropertyValue(v).trim() || fb);
  let mossHex = css('--moss', '#5E6B52'), redHex = css('--accent', '#BC3B2E'), groundHex = css('--ground', '#E4E5DE');
  scene.fog = new THREE.FogExp2(new THREE.Color(groundHex).getHex(), 0.028);

  const camera = new THREE.PerspectiveCamera(50, W() / H(), 0.1, 200);
  const Z0 = 22;
  camera.position.set(0, 0.3, Z0);

  scene.add(new THREE.AmbientLight(0x9aa08c, 1.0));
  const key = new THREE.DirectionalLight(new THREE.Color(mossHex).getHex(), 1.8); key.position.set(5, 9, 8); scene.add(key);
  const rim = new THREE.DirectionalLight(new THREE.Color(redHex).getHex(), 1.1); rim.position.set(-8, -3, -6); scene.add(rim);

  const COUNT = innerWidth < 640 ? 360 : 660;        // restraint + mobile budget
  const nStruct = Math.floor(COUNT * 0.68), nDrift = COUNT - nStruct;   // more gate, fewer floaters (間)

  const geo = new THREE.IcosahedronGeometry(0.13, 0);                       // low-poly stone mote
  const mat = new THREE.MeshStandardMaterial({ roughness: 0.7, metalness: 0.05 });
  const mesh = new THREE.InstancedMesh(geo, mat, COUNT);                    // ~1 draw call for the whole gate
  mesh.instanceMatrix.setUsage(THREE.DynamicDrawUsage);
  scene.add(mesh);

  let _s = 0.731; const rng = () => (_s = Math.sin(_s * 99991) * 9973, _s - Math.floor(_s));

  // torii (ธรณีประตู): two pillars + curved lintel (kasagi) + lower rail (nuki)
  const GW = 4.0, yBot = -4.2, yTopPillar = 3.2, lintelY = 4.2, nukiY = 2.3, ext = 1.3, lift = 0.7;
  const lenP = yTopPillar - yBot, lenL = 2 * (GW + ext), lenN = 2 * GW, totL = lenP * 2 + lenL + lenN;
  const cPL = lenP / totL, cPR = cPL + lenP / totL, cLin = cPR + lenL / totL;
  const struct = new Float32Array(nStruct * 3);
  for (let i = 0; i < nStruct; i++) {
    const f = i / nStruct, u = rng(), j = () => (rng() - 0.5) * 0.11; let x, y;
    if (f < cPL) { x = -GW + j(); y = yBot + u * lenP + j(); }
    else if (f < cPR) { x = GW + j(); y = yBot + u * lenP + j(); }
    else if (f < cLin) { x = -(GW + ext) + u * lenL + j(); y = lintelY + Math.pow(Math.abs(2 * u - 1), 1.6) * lift + j(); }
    else { x = -GW + u * lenN + j(); y = nukiY + j(); }
    struct[i * 3] = x; struct[i * 3 + 1] = y; struct[i * 3 + 2] = j();
  }

  // drift motes = ผัสสะ flowing toward the gate (-z), wrap when past
  const drift = new Float32Array(nDrift * 3), dspd = new Float32Array(nDrift);
  for (let i = 0; i < nDrift; i++) {
    drift[i * 3] = (rng() - 0.5) * 13; drift[i * 3 + 1] = (rng() - 0.5) * 9; drift[i * 3 + 2] = 4 + rng() * 22;
    dspd[i] = 0.4 + rng() * 0.9;
  }

  // colors: gate = moss (stone), drift = moss↔red (perception sparks), two accents only
  function applyColors() {
    const moss = new THREE.Color(mossHex), red = new THREE.Color(redHex), c = new THREE.Color();
    for (let i = 0; i < nStruct; i++) { c.copy(moss).offsetHSL(0, 0, (rng() - 0.5) * 0.06); mesh.setColorAt(i, c); }
    for (let i = 0; i < nDrift; i++) { c.copy(moss).lerp(red, 0.10 + rng() * 0.32); mesh.setColorAt(nStruct + i, c); }
    if (mesh.instanceColor) mesh.instanceColor.needsUpdate = true;
  }
  applyColors();

  const dummy = new THREE.Object3D();
  const scl = new Float32Array(COUNT); for (let i = 0; i < COUNT; i++) scl[i] = 0.5 + rng() * 0.5;  // finer, capped
  let mx = 0, my = 0, prog = 0, target = 0;
  addEventListener('pointermove', e => { mx = e.clientX / innerWidth - 0.5; my = e.clientY / innerHeight - 0.5; }, { passive: true });
  const heroH = () => Math.max(1, hero.offsetHeight * 0.9);
  addEventListener('scroll', () => { target = Math.min(1, Math.max(0, scrollY / heroH())); }, { passive: true });

  const clock = new THREE.Clock();
  function frame(dt) {
    const t = clock.elapsedTime;
    for (let i = 0; i < nStruct; i++) {
      const ix = i * 3, br = reduce ? 0 : Math.sin(t * 0.5 + i) * 0.05;
      dummy.position.set(struct[ix], struct[ix + 1] + br, struct[ix + 2]);
      dummy.rotation.set(t * 0.05 + i, t * 0.04, 0); dummy.scale.setScalar(scl[i]);
      dummy.updateMatrix(); mesh.setMatrixAt(i, dummy.matrix);
    }
    for (let i = 0; i < nDrift; i++) {
      const ix = i * 3;
      if (!reduce) {
        drift[ix + 2] -= dspd[i] * dt;
        if (drift[ix + 2] < -6) { drift[ix + 2] = 20 + rng() * 6; drift[ix] = (rng() - 0.5) * 13; drift[ix + 1] = (rng() - 0.5) * 9; }
        drift[ix] += Math.sin(t * 0.3 + i) * 0.004; drift[ix + 1] += Math.cos(t * 0.27 + i) * 0.004;
      }
      dummy.position.set(drift[ix], drift[ix + 1], drift[ix + 2]);
      dummy.rotation.set(t * 0.1 + i, t * 0.08, 0); dummy.scale.setScalar(scl[nStruct + i] * 0.5);
      dummy.updateMatrix(); mesh.setMatrixAt(nStruct + i, dummy.matrix);
    }
    mesh.instanceMatrix.needsUpdate = true;

    prog += (target - prog) * (reduce ? 1 : 0.06);   // camera dollies THROUGH the gate on scroll
    camera.position.x += ((mx * 2.2) - camera.position.x) * 0.05;
    camera.position.y += ((0.3 - my * 1.4) - camera.position.y) * 0.05;
    camera.position.z += ((Z0 - prog * 26) - camera.position.z) * 0.07;
    camera.lookAt(0, 0.3 + prog * 1.2, -prog * 10);
    renderer.render(scene, camera);
  }

  // theme switch → recompute colors/lights/fog (keeps 3D in sync with light/dark toggle)
  new MutationObserver(() => {
    mossHex = css('--moss', mossHex); redHex = css('--accent', redHex); groundHex = css('--ground', groundHex);
    key.color.set(mossHex); rim.color.set(redHex); scene.fog.color.set(groundHex); applyColors();
    if (reduce) frame(0);
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  addEventListener('resize', () => {
    renderer.setSize(W(), H(), false); camera.aspect = W() / H(); camera.updateProjectionMatrix(); if (reduce) frame(0);
  }, { passive: true });

  if (reduce) { frame(0); }                            // static gate, fully formed, no loop
  else { (function loop() { frame(clock.getDelta()); requestAnimationFrame(loop); })(); }
} catch (err) {
  console.warn('3D gate disabled: content stays fully visible', err);
}
</script>

</body>
</html>
